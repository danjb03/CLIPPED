# Copy to .env.local and fill in. Read by BOTH the web app and the Python worker.
# .env.local is git-ignored.

# Clip selection + post copy (Phase 2 / 6)
ANTHROPIC_API_KEY=

# Transcription is local (faster-whisper) — no key needed.
# Diarisation uses pyannote, which needs a (free) Hugging Face token AND you must
# accept the model terms at https://hf.co/pyannote/speaker-diarization-3.1
# Without this, transcription still runs but everyone is labelled speaker "A".
HUGGINGFACE_TOKEN=

# Whisper config (optional)
WHISPER_MODEL=base          # tiny | base | small | medium | large-v3
WHISPER_DEVICE=cpu          # cpu | cuda
WHISPER_COMPUTE=int8        # int8 (cpu) | float16 (cuda)

# Wiring
WORKER_PORT=8000
NEXT_PUBLIC_WORKER_URL=http://localhost:8000
